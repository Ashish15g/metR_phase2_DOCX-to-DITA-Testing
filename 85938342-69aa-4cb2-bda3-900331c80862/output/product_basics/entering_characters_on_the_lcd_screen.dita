<task id="Entering_Characters_on_the_LCD_Screen" xml:lang="en-us">
  <title>Entering Characters on the LCD Screen</title>
  <shortdesc>Follow these guidelines to enter characters for passwords and other settings.</shortdesc>
  <prolog>
    <metadata>
      <keywords>
        <keyword>select</keyword>
        <keyword>press</keyword>
        <keyword>Entering</keyword>
