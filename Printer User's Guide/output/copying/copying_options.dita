        <indexterm>original</indexterm>
        <indexterm>copies</indexterm>
      </keywords>
      <prodinfo>
        <prodname></prodname>
      </prodinfo>
    </metadata>
  </prolog>
  <taskbody>  <context>
    <p>Select the copying options you want to use for your copies.</p><note type="note">Not all options or settings may be available, depending on other copying settings.</note><p>
