        <b>Settings</b>
      </p><table frame="all" colsep="1" rowsep="1">
        <tgroup cols="3">
          <colspec colname="col1" colnum="1" colwidth="1*"/>
          <colspec colname="col2" colnum="2" colwidth="1*"/>
          <colspec colname="col3" colnum="3" colwidth="1*"/>
          <tbody>
            <row>
              <entry>
                <b>Copying</b>
                <b>option</b>
              </entry>
              <entry>
                <b>Available</b>
                <b>settings</b>
              </entry>
              <entry>
                <b>Description</b>
              </entry>
            </row>
            <row>
              <entry morerows="1">
                <b>2-Sided</b>
              </entry>
              <entry>
                <b>1&gt;1-Sided</b>
              </entry>
              <entry morerows="1">Select to make 2-sided copies. When you select <b>1&gt;2-Sided</b>, also select the orientation and binding edge for your originals or copies.</entry>
            </row>
            <row>
              <entry>
                <b>1&gt;2-Sided</b>
              </entry>
            </row>
            <row>
              <entry>
                <b>Density</b>
              </entry>
