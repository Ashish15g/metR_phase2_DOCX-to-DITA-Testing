            </row>
          </tbody>
        </tgroup>
      </table><table frame="all" colsep="1" rowsep="1">
        <tgroup cols="3">
          <colspec colname="col1" colnum="1" colwidth="1*"/>
          <colspec colname="col2" colnum="2" colwidth="1*"/>
          <colspec colname="col3" colnum="3" colwidth="1*"/>
          <tbody>
            <row>
              <entry>
                <b>Copying</b>
                <b>option</b>
