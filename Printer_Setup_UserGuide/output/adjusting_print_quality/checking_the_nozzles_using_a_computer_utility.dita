<task id="Checking_the_Nozzles_Using_a_Computer_Ut" xml:lang="en-us">
  <title>Checking the Nozzles Using a Computer Utility</title>
  <shortdesc>You can check the print head nozzles using a utility on your Windows or Mac</shortdesc>
  <prolog>
    <metadata>
      <keywords>
        <keyword>Print</keyword>
        <keyword>click</keyword>
        <keyword>Utility</keyword>
        <keyword>print</keyword>
        <keyword>Windows</keyword>
        <keyword>there</keyword>
        <indexterm>Print</indexterm>
        <indexterm>click</indexterm>
